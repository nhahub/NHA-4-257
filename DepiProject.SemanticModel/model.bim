            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "Distance_km",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "double",
            "expression": [
              "",
              "VAR lat1 = RADIANS('Zomato Dataset'[Restaurant_Lat_Clean])",
              "VAR lon1 = RADIANS('Zomato Dataset'[Restaurant_Long_Clean])",
              "VAR lat2 = RADIANS('Zomato Dataset'[Delivery_location_latitude])",
              "VAR lon2 = RADIANS('Zomato Dataset'[Delivery_location_longitude])",
              "VAR dlat = lat2 - lat1",
              "VAR dlon = lon2 - lon1",
              "VAR a = SIN(dlat/2)^2 + COS(lat1) * COS(lat2) * SIN(dlon/2)^2",
              "VAR c = 2 * ASIN(SQRT(a))",
              "VAR R = 6371 -- Earth's radius in km",
              "RETURN R * c"
            ],
            "formatString": "0.00",
            "isDataTypeInferred": true,
            "lineageTag": "4e4fd2d4-6f36-424e-a287-5b9c90a604bb",
            "summarizeBy": "sum",
