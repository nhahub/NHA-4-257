                "    #\"Changed Type6\" = Table.TransformColumnTypes(#\"Replaced Value8\",{{\"Vehicle_condition\", Int64.Type}}),",
                "    #\"Added Conditional Column\" = Table.AddColumn(#\"Changed Type6\", \"Delivery_Status\", each if [#\"Time_taken (min)\"] <= 30 then \"on time\" else if [#\"Time_taken (min)\"] <= 45 then \"delayed\" else \"very delayed\"),",
                "    #\"Added Conditional Column1\" = Table.AddColumn(#\"Added Conditional Column\", \"Delay Category\", each if [#\"Time_taken (min)\"] <= 30 then \"On time\" else if [#\"Time_taken (min)\"] <= 45 then \"delayed\" else \"very delayed\"),",
                "    #\"Filtered Rows6\" = Table.SelectRows(#\"Added Conditional Column1\", each true)",
                "in",
                "    #\"Filtered Rows6\""
              ],
              "type": "m"
            }
          }
        ]
