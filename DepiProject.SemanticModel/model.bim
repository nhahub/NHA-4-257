          {
            "name": "page3_Order_Prep_Time_min",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "int64",
            "expression": [
              "",
              "VAR StartTime = 'Zomato Dataset'[Cleaned_Time_Orderd]",
              "VAR EndTime = 'Zomato Dataset'[Cleaned_Time_Order_picked]",
              "VAR RawMinutes = DATEDIFF(StartTime, EndTime, MINUTE)",
              "RETURN ",
              "    IF(",
              "        RawMinutes < 0, ",
              "        RawMinutes + 1440, ",
              "        RawMinutes",
              "    )"
            ],
            "formatString": "0",
            "isDataTypeInferred": true,
