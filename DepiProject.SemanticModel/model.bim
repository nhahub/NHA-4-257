              },
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "dataType": "int64",
            "expression": "'Zomato Dataset'[Time_taken (min)] - 'Zomato Dataset'[page3_Order_Prep_Time_min]",
            "isDataTypeInferred": true,
            "lineageTag": "5b6deef5-ae82-40ac-947e-97a6bc42a725",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "page3_Distance_km",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "double",
            "expression": [
              "",
              "VAR Lat1 = RADIANS('Zomato Dataset'[Restaurant_latitude])",
              "VAR Lon1 = RADIANS('Zomato Dataset'[Restaurant_longitude])",
              "VAR Lat2 = RADIANS('Zomato Dataset'[Delivery_location_latitude])",
              "VAR Lon2 = RADIANS('Zomato Dataset'[Delivery_location_longitude])",
              "",
              "VAR dLat = Lat2 - Lat1",
              "VAR dLon = Lon2 - Lon1",
              "",
              "VAR a = SIN(dLat / 2)^2 + COS(Lat1) * COS(Lat2) * SIN(dLon / 2)^2",
              "VAR c = 2 * ASIN(SQRT(a))",
              "VAR R = 6371 ",
              "",
              "RETURN R * c"
            ],
            "formatString": "0.00",
            "isDataTypeInferred": true,
            "lineageTag": "6adc823f-7ea9-47ae-a612-eee9fe1fa925",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "page3_Speed_kmph",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "double",
            "expression": [
              "",
              "IF(",
              "    'Zomato Dataset'[Time_taken (min)] > 0,",
              "    'Zomato Dataset'[Distance_km] / ('Zomato Dataset'[Time_taken (min)] / 60),",
              "    BLANK()",
              ")"
            ],
            "formatString": "0.00",
            "isDataTypeInferred": true,
            "lineageTag": "6cb6fb55-5321-48fe-bc19-bc4cd04c0357",
            "summarizeBy": "sum",
            "type": "calculated"
          },
          {
            "name": "page3_Bottleneck_Flag",
            "annotations": [
              {
                "name": "SummarizationSetBy",
                "value": "Automatic"
              }
            ],
            "dataType": "string",
            "expression": [
              "",
              "VAR MedianPrep = MEDIAN('Zomato Dataset'[page3_Order_Prep_Time_min])",
              "VAR MedianTransit = MEDIAN('Zomato Dataset'[page3_Transit_Time_min])",
              "VAR CurrentPrep = 'Zomato Dataset'[page3_Order_Prep_Time_min]",
              "VAR CurrentTransit = 'Zomato Dataset'[page3_Transit_Time_min]",
              "RETURN",
              "    SWITCH(",
              "        TRUE(),",
              "        CurrentPrep > MedianPrep && CurrentTransit > MedianTransit, \"Both delayed\",",
              "        CurrentPrep > MedianPrep, \"Kitchen delay\",",
              "        CurrentTransit > MedianTransit, \"Road delay\",",
              "        \"Normal\"",
              "    )"
            ],
            "isDataTypeInferred": true,
            "lineageTag": "544f04cf-d37f-4f27-8a64-0011b44695fc",
            "summarizeBy": "none",
            "type": "calculated"
          },
          {
            "name": "Delivery_Status",
