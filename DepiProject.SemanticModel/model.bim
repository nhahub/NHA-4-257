                "    #\"Changed Type with Locale1\" = Table.TransformColumnTypes(#\"Changed Type4\", {{\"Cleaned_Time_Orderd\", type time}}, \"en-GB\"),",
                "    #\"Filtered Rows4\" = Table.SelectRows(#\"Changed Type with Locale1\", each true),",
                "    #\"Replaced Value7\" = Table.ReplaceValue(#\"Filtered Rows4\",\"NaN\",\"\",Replacer.ReplaceText,{\"Festival\"}),",
                "    #\"Changed Type5\" = Table.TransformColumnTypes(#\"Replaced Value7\",{{\"Time_taken (min)\", Int64.Type}}),",
                "    #\"Filtered Rows5\" = Table.SelectRows(#\"Changed Type5\", each true),",
