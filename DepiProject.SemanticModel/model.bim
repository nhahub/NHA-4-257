                "    #\"Replaced Value2\" = Table.ReplaceValue(#\"Replaced Value3\",\"NaN\",null,Replacer.ReplaceValue,{\"multiple_deliveries\"}),",
                "    #\"Replaced Value4\" = Table.ReplaceValue(#\"Replaced Value2\",\"NaN\",null,Replacer.ReplaceValue,{\"City\"}),",
                "    #\"Filtered Rows3\" = Table.SelectRows(#\"Replaced Value4\", each true),",
