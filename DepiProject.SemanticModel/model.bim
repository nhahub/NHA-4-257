        "measures": [
          {
            "name": "Total Deliveries",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "COUNT('Zomato Dataset'[ID])"
            ],
            "lineageTag": "d30f8a31-3c48-4250-8d0e-3f10ec4301cb"
          },
          {
            "name": "Avg Rating",
            "annotations": [
              {
                "name": "PBI_FormatHint",
                "value": "{\"isGeneralNumber\":true}"
              }
            ],
            "expression": [
              "",
              "AVERAGE('Zomato Dataset'[Delivery_person_Ratings])"
            ],
            "lineageTag": "c1a1ec4c-2820-4a21-b560-be3a9c5de5ee"
          },
          {
            "name": "Late Deliveries",
            "expression": [
              "",
              "CALCULATE(",
              "    COUNT('Zomato Dataset'[ID]),",
              "    'Zomato Dataset'[Time_taken (min)] > 40",
              ")"
            ],
            "formatString": "0",
            "lineageTag": "27f5cca1-75b3-427a-9f43-240702963ee6"
          },
          {
            "name": "Delay Rate %",
            "expression": [
              "",
              "DIVIDE(",
              "    CALCULATE(",
              "        COUNT('Zomato Dataset'[ID]),",
              "        'Zomato Dataset'[Delay Category] <> \"On Time\"",
              "    ),",
              "    COUNT('Zomato Dataset'[ID])",
              ")"
            ],
            "formatString": "0.00%;-0.00%;0.00%",
            "lineageTag": "fed6ea5b-91e6-4b4f-96b7-9423589bd960"
          }
        ],
