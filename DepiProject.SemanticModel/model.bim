                "else if Text.Contains(Text.From([Time_Orderd]), \".\") or [Time_Orderd] = \"1\" then ",
                "    Time.From(Number.From([Time_Orderd])) ",
                "else ",
                "    Time.From([Time_Orderd])),",
                "    #\"Changed Type2\" = Table.TransformColumnTypes(#\"Added Custom\",{{\"Cleaned_Time_Ordered\", type time}}),",
                "    #\"Added Custom1\" = Table.AddColumn(#\"Changed Type2\", \"Cleaned_Time_Order_Picked\", each if [Time_Order_picked] = \"NaN\" or [Time_Order_picked] = null then null ",
                "else if Text.Contains(Text.From([Time_Order_picked]), \".\") or [Time_Order_picked] = \"1\" then ",
                "    Time.From(Number.From([Time_Order_picked])) ",
                "else ",
                "    Time.From([Time_Order_picked])),",
                "    #\"Removed Columns\" = Table.RemoveColumns(#\"Added Custom1\",{\"Cleaned_Time_Ordered\", \"Cleaned_Time_Order_Picked\"}),",
                "    #\"Added Custom2\" = Table.AddColumn(#\"Removed Columns\", \"Cleaned_Time_Orderd\", each let",
                "    currentValue = Text.From([Time_Orderd]),",
                "    replaced24 = if Text.StartsWith(currentValue, \"24:\") then \"00:\" & Text.AfterDelimiter(currentValue, \"24:\") else currentValue,",
                "    finalValue = if replaced24 = \"1\" or replaced24 = \"1.0\" or replaced24 = \"NaN\" or replaced24 = null then \"00:00\" else replaced24",
                "in",
